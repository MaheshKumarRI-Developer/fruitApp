# Root .gitignore for Fruit App

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python virtual environment and cache
venv/
.venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE/Editor config
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Frontend build outputs
dist/
dist-ssr/
build/

# Local database/vector db mounts (if any are saved locally)
qdrant_storage/
